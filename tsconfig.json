{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Interop (IMPORTANT for express import)
    "esModuleInterop": true,

    // Environment Settings (fixed for Node + Express)
    "module": "commonjs",              // ✅ changed from nodenext
    "moduleResolution": "node",        // ✅ added
    "target": "es6",                   // ✅ simplified
    "types": ["node"],                 // ✅ added

    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    // "declaration": true,            // ❌ not needed now
    // "declarationMap": true,         // ❌ not needed now

    // Stricter Typechecking Options
    // "noUncheckedIndexedAccess": true,       // optional
    // "exactOptionalPropertyTypes": true,     // optional

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,

    // ❌ Not needed for backend
    // "jsx": "react-jsx",

    // ❌ causing your error
    "verbatimModuleSyntax": false,

    // Optional but safe
    "isolatedModules": true,

    // ❌ not needed
    // "noUncheckedSideEffectImports": true,

    // ❌ not needed
    // "moduleDetection": "force",

    "skipLibCheck": true
  }
}